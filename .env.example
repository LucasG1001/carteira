# Credenciais do PostgreSQL (dedicadas a este projeto)
POSTGRES_USER=carteira
POSTGRES_PASSWORD=troque-esta-senha
POSTGRES_DB=carteira

# Domínio servido pelo proxy reverso central (stack ./proxy compartilhada) via HTTPS.
# Acesse pela rede WireGuard em: https://grana.gomeslab.tech
# O A record de CARTEIRA_DOMAIN (no painel DNS) aponta para o IP da VPN.
# Usado nas labels do serviço web para o caddy-docker-proxy rotear o domínio.
CARTEIRA_DOMAIN=grana.gomeslab.tech
