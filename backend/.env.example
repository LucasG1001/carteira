# PostgreSQL (para dev local; no Docker estes valores vêm do compose)
DB_HOST=localhost
DB_PORT=5432
DB_USER=carteira
DB_PASSWORD=troque-esta-senha
DB_NAME=carteira

# Usuário único (app sem autenticação)
SINGLE_USER_ID=local

# CORS
ALLOWED_ORIGINS=["*"]

# Sincronização de cotações (yfinance)
MARKET_DATA_TIMEZONE=America/Sao_Paulo
STOCK_SYNC_START_HOUR=10
STOCK_SYNC_END_HOUR=18
STOCK_SYNC_SUBMISSION_DELAY_SECONDS=1.0
STOCK_SYNC_LOG_FILE=app.log
